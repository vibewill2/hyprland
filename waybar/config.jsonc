{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["keyboard", "network", "cpu", "memory", "temperature", "disk", "pulseaudio", "backlight", "battery", "tray"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": [],
            "7": [],
            "8": [],
            "9": []
        },
        "format": "{icon}",
        "format-icons": {
            "1": "َ°„¯",
            "2": "َ°„¯",
            "3": "َ°„¯",
            "4": "َ°„¯",
            "5": "َ°„¯",
            "6": "َ°„¯",
            "7": "َ°„¯",
            "8": "َ°„¯",
            "9": "َ°„¯",
            "active": "َ°€ڑ",
            "default": "َ°„¯"
        }
    },

    "hyprland/window": {
        "format": "َ±‚¬ {title}",
        "max-length": 30,
        "separate-outputs": true
    },

    "keyboard": {
        "format": "âŒ¨ {output}",
        "exec": "swaymsg -t get_inputs | jq -r '.[] | select(.identifier | test(\"keyboard\")) | .xkb_active_layout_name'",
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol"
    },

    "cpu": { "format": "َ°چ› {usage}%" },
    "memory": { "format": "َ°¾† {percentage}%" },

    "temperature": {
        "thermal-zone": 0,
        "format": "َ°”ڈ {temperatureC}آ°C"
    },

    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {percentage_used}%"
    },

    "network": {
        "format-wifi": "َ°¤¨ {essid}",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤®"
    },

    "backlight": {
        "format": "َ°ƒ  {percent}%"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "format": "َ°¥” {:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }
}